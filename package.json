{
  "name": "pulse",
  "version": "2.10.0",
  "description": "macOS 菜单栏更新监测器 — Pulse",
  "main": "src/main/index.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer/index.jsx --bundle --format=iife --outfile=renderer-dist/renderer.bundle.js --loader:.jsx=jsx --jsx=automatic --jsx-import-source=preact --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\"",
    "prestart": "npm run build:renderer",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder --mac",
    "dev": "npm run build:renderer && NODE_ENV=development electron .",
    "test": "vitest"
  },
  "author": "Pulse",
  "license": "MIT",
  "dependencies": {
    "@preact/signals": "^1.3.0",
    "dompurify": "^3.4.8",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.5",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/preact": "^3.2.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.5",
    "happy-dom": "^15.11.7",
    "jsdom": "^29.1.1",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.appupdatechecker.pulse",
    "productName": "Pulse",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "src/**",
      "preload.js",
      "config.json",
      "config/**",
      "index.html",
      "styles.css",
      "renderer-dist/renderer.bundle.js",
      "assets/**",
      "package.json",
      "node_modules/**"
    ]
  }
}
