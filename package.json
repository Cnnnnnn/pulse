{
  "name": "pulse",
  "version": "2.22.0",
  "description": "macOS 菜单栏更新监测器 — Pulse",
  "main": "src/main/index.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer/index.jsx --bundle --format=iife --outfile=renderer-dist/renderer.bundle.js --loader:.jsx=jsx --jsx=automatic --jsx-import-source=preact --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\" && esbuild src/renderer/ithome/NewsShareCardPage.jsx --bundle --format=iife --outfile=renderer-dist/news-share-card.bundle.js --loader:.jsx=jsx --jsx=automatic --jsx-import-source=preact --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\"",
    "prestart": "npm run build:renderer",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac --publish never",
    "build:win": "npm run build:renderer && electron-builder --win --publish never",
    "build:all": "npm run build:renderer && electron-builder --mac --win --publish never",
    "dev": "npm run build:renderer && NODE_ENV=development electron .",
    "test": "vitest"
  },
  "author": "Pulse",
  "license": "MIT",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@preact/signals": "^1.3.0",
    "dompurify": "^3.4.8",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.5",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/preact": "^3.2.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.5",
    "happy-dom": "^15.11.7",
    "jsdom": "^29.1.1",
    "png-to-ico": "^2.1.8",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.appupdatechecker.pulse",
    "productName": "Pulse",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ],
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Pulse-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterPack": "build/after-pack.cjs",
    "asarUnpack": [
      "**/node_modules/@napi-rs/keyring*/**"
    ],
    "files": [
      "src/**",
      "preload.js",
      "config.json",
      "config/**",
      "index.html",
      "styles.css",
      "share-card.html",
      "renderer-dist/renderer.bundle.js",
      "renderer-dist/news-share-card.bundle.js",
      "assets/**",
      "package.json",
      "node_modules/**"
    ]
  }
}
