{
  "name": "pulse",
  "version": "2.79.3",
  "description": "macOS 菜单栏更新监测器 — Pulse",
  "main": "src/main/index.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer/index.jsx --bundle --format=esm --splitting --outdir=renderer-dist --entry-names=[name] --chunk-names=chunk-[hash] --loader:.jsx=jsx --jsx=automatic --jsx-import-source=preact --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\" && esbuild src/renderer/ithome/NewsShareCardPage.jsx --bundle --format=iife --outfile=renderer-dist/news-share-card.bundle.js --loader:.jsx=jsx --jsx=automatic --jsx-import-source=preact --target=es2020 --define:process.env.NODE_ENV=\\\"production\\\" && node scripts/merge-renderer-css.cjs",
    "prestart": "npm run build:renderer",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:mac": "npm run build:renderer && electron-builder --mac --arm64 --x64 --publish never",
    "build:mac:arm64-only": "npm run build:renderer && electron-builder --mac --arm64 --publish never",
    "build:mac:x64-only": "npm run build:renderer && electron-builder --mac --x64 --publish never",
    "build:mac:all": "npm run build:mac",
    "build:win": "npm run build:renderer && electron-builder --win --x64 --publish never",
    "build:all": "npm run build:mac:all && npm run build:win",
    "dev": "npm run build:renderer && NODE_ENV=development electron .",
    "test": "vitest",
    "test:visual": "playwright test --config=playwright.config.js",
    "test:visual:update": "playwright test --config=playwright.config.js --update-snapshots",
    "lint:css": "stylelint \"src/renderer/components/**/*.css\"",
    "baseline:q4": "node scripts/q4-baseline.js"
  },
  "author": "Pulse",
  "license": "MIT",
  "dependencies": {
    "@preact/signals": "^1.3.0",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.5",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/preact": "^3.2.4",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "png-to-ico": "^2.1.8",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "@noble/hashes": "1.7.1"
  },
  "build": {
    "appId": "com.appupdatechecker.pulse",
    "productName": "Pulse",
    "publish": {
      "provider": "github",
      "owner": "Cnnnnnn",
      "repo": "pulse"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Pulse-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterPack": "build/after-pack.cjs",
    "files": [
      "src/**",
      "preload.js",
      "config.json",
      "config/**",
      "index.html",
      "styles.css",
      "share-card.html",
      "renderer-dist/index.js",
      "renderer-dist/index.css",
      "renderer-dist/chunk-*.js",
      "renderer-dist/chunk-*.css",
      "renderer-dist/news-share-card.bundle.js",
      "assets/**",
      "package.json",
      "node_modules/**"
    ]
  }
}
